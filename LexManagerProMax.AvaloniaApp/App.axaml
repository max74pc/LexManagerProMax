<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LexManagerProMax.AvaloniaApp.App"
             xmlns:local="using:LexManagerProMax.AvaloniaApp"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->


	<Application.Styles>
		<FluentTheme />
		<StyleInclude Source="avares://LexManagerProMax.AvaloniaApp/Styles/LexManagerProMaxStyles.axaml" />
	</Application.Styles>
</Application>